{
  "name": "opencarbo",
  "version": "0.2.8",
  "description": "AI coding assistant CLI - powered by OpenAI/OpenRouter",
  "type": "module",
  "bin": {
    "opencarbo": "./cli.mjs"
  },
  "scripts": {
    "dev": "bun --watch src/entrypoints/cli.tsx",
    "start": "bun src/entrypoints/cli.tsx",
    "build": "bun build src/entrypoints/cli.tsx --outfile cli.mjs --target bun --minify",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^12.1.0",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "ansi-escapes": "^7.0.0",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "cli-table3": "^0.6.5",
    "debug": "^4.4.0",
    "diff": "^7.0.0",
    "dotenv": "^16.4.7",
    "env-paths": "^3.0.0",
    "figures": "^6.1.0",
    "glob": "^11.0.1",
    "ink": "^5.2.0",
    "ink-link": "^4.1.0",
    "lodash-es": "^4.17.21",
    "lru-cache": "^11.0.2",
    "marked": "^15.0.7",
    "openai": "^4.85.0",
    "react": "^18.3.1",
    "react-devtools-core": "^4.28.5",
    "semver": "^7.7.1",
    "shell-quote": "^1.8.2",
    "signal-exit": "^3.0.7",
    "spawn-rx": "^5.1.2",
    "string-width": "7",
    "wrap-ansi": "^9.0.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/diff": "^7.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.18",
    "@types/semver": "^7.5.8",
    "@types/shell-quote": "^1.7.5",
    "typescript": "^6.0.2"
  }
}
