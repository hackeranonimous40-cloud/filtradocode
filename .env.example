# OpenCarbo Configuration
# Copy this to .env and fill in your values

# API Key from Kilo AI (https://kilo.ai)
OPENAI_API_KEY=your-kilo-api-key-here

# API Base URL (Kilo endpoint)
OPENAI_BASE_URL=https://api.kilo.ai/api/openrouter

# Model to use (Qwen 3.6 Plus Free via Kilo)
OPENAI_MODEL=qwen/qwen3.6-plus-preview:free
OPENAI_SMALL_MODEL=qwen/qwen3.6-plus-preview:free
